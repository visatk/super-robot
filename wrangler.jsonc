{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "super-robot",
	"main": "src/index.ts",
	"compatibility_date": "2026-06-12",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"placement": {
    "mode": "smart"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "super-robot",
      "database_id": "7feb13df-0e67-4e91-94b1-e888bf052d05"
    }
  ]
}
